# ── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=1448_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=1448_db
DATABASE_URL=postgres://1448_user:change_me_in_production@postgres:5432/1448_db?sslmode=disable

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── SERVER ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── TWILIO (OTP SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# ── PGADMIN ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@1448.dev
PGADMIN_PASSWORD=admin

# ── STRIPE (платёжный шлюз ЕС) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_BLIK_ENABLED=true             # BLIK — польская платёжная система (через Stripe)

# ── GOOGLE MAPS (геолокация клубов) ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── ЛОКАЛИЗАЦИЯ ───────────────────────────────────────────────────────────────
APP_LOCALE=pl                          # pl / en / ru
APP_TIMEZONE=Europe/Warsaw
APP_CURRENCY=PLN
