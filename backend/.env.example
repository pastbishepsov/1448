# ============================================================
# 14:48 Backend — переменные окружения
# Скопируй этот файл в .env и заполни значения
# НЕ коммить .env в Git!
# ============================================================

# Сервер
PORT=8080
ENV=development   # development | production

# База данных (PostgreSQL)
DATABASE_URL=postgres://user_1448:pass_1448_dev@localhost:5432/db_1448?sslmode=disable

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=redis_1448_dev

# JWT
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Twilio (SMS OTP)
# Зарегистрируйся на twilio.com и получи бесплатный trial
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
